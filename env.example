# ============================================================
# Discord Moderation Sync Bot - Example Environment File
# Copy this file to `.env` and replace placeholder values.
# ============================================================

# Discord bot token from the Discord Developer Portal.
# NEVER commit your real token.
DISCORD_TOKEN=

# Comma-separated Discord user IDs allowed to use owner slash commands.
BOT_OWNER_IDS=

# Everything else is stored in data/moderation.sqlite3.
# Use owner slash commands like /config_set, /config_id_add, and /config_list
# to configure home guild, staff roles, log threads, feature toggles, and bot behavior.
